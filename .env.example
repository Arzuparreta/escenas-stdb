# Path to the stdbKit SQLite database (shared with relay/webhooks)
STDBKIT_DB_PATH=data/cinema.db

# YouTube playlist your uncle curates — relay watches this automatically
YOUTUBE_PLAYLIST_URL=https://www.youtube.com/playlist?list=YOUR_PLAYLIST_ID

# Optional shared secret between relay and webhook server
# STDBKIT_SECRET=

RELAY_INTERVAL_SEC=30
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8787

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
